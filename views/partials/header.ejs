<header id="top-header" class="top-header"> 
  <section class="logo">
  <span class="siteName">
    <a href="/" title="Return to home page">CSE Motors</a>
  </span>

  <ul class="loging-process">
    <% if (loggedin) { %>

      <li>
        <a href="/account/" title="Account Management">
          Welcome <%= accountData.account_firstname %>
        </a>
      </li>

      <li>
        <a href="/account/logout" title="Logout">Logout</a>
      </li>

    <% } else { %>

      <li>
        <a href="/account/login" title="My Account">My Account</a>
      </li>

    <% } %>
  </ul>
  </section>
  <section class="favorites">
    <% if (loggedin) { %>
        <a href="/account/favorites" title="Favorites">
          Favorites ❤️
        </a>
    <% } %>
  </section>
</header>