<% if (title) { %>
<h1><%= title %></h1>
<% } else {
  res.redirect('/')
} %>
 
 
<%- messages() %>

<!-- Error Messages -->
<% if (errors) { %>
  <ul class="notice">
 <% errors.array().forEach(error => { %>
   <li><%= error.msg %></li>
<%  }) %>
 </ul>
<% } %>

<p>Confirm Deletion - The delete is permanent.</p>
<form id="addInventoryForm" class="addInventoryForm" action="/inv/remove" method="post">

 <!-- Make -->
  <label for="inv_make">Make</label>
  <input 
    type="text" 
    id="inv_make" 
    name="inv_make" 
    required
    minlength="2"
    maxlength="50"
    pattern="^[A-Za-z0-9]+$"
    title="Make should contain letters and numbers only"
    value="<%= locals.inv_make %>"
    readonly>

  <!-- Model -->
  <label for="inv_model">Model</label>
  <input 
    type="text" 
    id="inv_model" 
    name="inv_model" 
    required
    minlength="1"
    maxlength="50"
    pattern="^[A-Za-z0-9]+$"
    title="Make should contain letters and numbers only"
    value="<%= locals.inv_model %>"
    readonly>

  <!-- Year -->
  <label for="inv_year">Year</label>
  <input 
    type="number" 
    id="inv_year" 
    name="inv_year" 
    required
    min="1900"
    max="2099"
    value="<%= locals.inv_year %>"
    readonly>  

  <!-- Price -->
  <label for="inv_price">Price ($)</label>
  <input 
    type="number" 
    id="inv_price" 
    name="inv_price" 
    required
    min="0"
    value="<%= locals.inv_price %>"
    readonly>

    <input type="hidden" name="inv_id"
    <% if(locals.inv_id) { %> value="<%= locals.inv_id %>"
    <% } %>>
  <input type="submit" name="submit" value="Delete Vehicle">
  
</form>