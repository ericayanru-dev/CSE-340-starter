<% if (title) { %>
<h1><%= title %></h1>
<% } else {
  res.redirect('/')
} %>
 
 
<%- messages() %>

<!-- Error Messages -->
<% if (errors) { %>
  <ul class="notice">
 <% errors.array().forEach(error => { %>
   <li><%= error.msg %></li>
<%  }) %>
 </ul>
<% } %>

<form id="addInventoryForm" class="addInventoryForm" action="/inv/update" method="post">

   <!-- Classification Dropdown -->
  <label for="classification_id">Classification</label>
  <select id="classification_id" name="classification_id" required>
    <%- classificationList %>
  </select> 

 <!-- Make -->
  <label for="inv_make">Make</label>
  <input 
    type="text" 
    id="inv_make" 
    name="inv_make" 
    required
    minlength="2"
    maxlength="50"
    pattern="^[A-Za-z0-9]+$"
    title="Make should contain letters and numbers only"
    value="<%= locals.inv_make %>">

  <!-- Model -->
  <label for="inv_model">Model</label>
  <input 
    type="text" 
    id="inv_model" 
    name="inv_model" 
    required
    minlength="1"
    maxlength="50"
    pattern="^[A-Za-z0-9]+$"
    title="Make should contain letters and numbers only"
    value="<%= locals.inv_model %>">

  <!-- Year -->
  <label for="inv_year">Year</label>
  <input 
    type="number" 
    id="inv_year" 
    name="inv_year" 
    required
    min="1900"
    max="2099"
    value="<%= locals.inv_year %>">
  

  <!-- Description -->
  <label for="inv_description">Description</label>
  <textarea 
    id="inv_description" 
    name="inv_description" 
    required
    maxlength="1000"
    ><%= locals.inv_description  || ''  %>
  </textarea>
  

  <!-- Image Path -->
  <label for="inv_image">Image Path</label>
  <input 
    type="text" 
    id="inv_image" 
    name="inv_image" 
    required
    pattern="^\/images\/.+\.(jpg|jpeg|png|webp)$"
    title="Must be a valid image path like /images/car.jpg"
    value="<%= locals.inv_image %>">

  <!-- Thumbnail Path -->
  <label for="inv_thumbnail">Thumbnail Path</label>
  <input 
    type="text" 
    id="inv_thumbnail" 
    name="inv_thumbnail" 
    required
    pattern="^\/images\/.+\.(jpg|jpeg|png|webp)$"
    title="Must be a valid image path like /images/car-thumb.jpg"
    value="<%= locals.inv_thumbnail %>">

  <!-- Price -->
  <label for="inv_price">Price ($)</label>
  <input 
    type="number" 
    id="inv_price" 
    name="inv_price" 
    required
    min="0"
    value="<%= locals.inv_price %>">

  <!-- Miles -->
  <label for="inv_miles">Mileage</label>
  <input 
    type="number" 
    id="inv_miles" 
    name="inv_miles" 
    required
    min="0"
    value="<%= locals.inv_miles %>">

  <!-- Color -->
  <label for="inv_color">Color</label>
  <input 
    type="text" 
    id="inv_color" 
    name="inv_color" 
    required
    pattern="^[A-Za-z]+$"
    title="Color should contain only letters"
    value="<%= locals.inv_color %>">

  <input type="submit" name="submit" value="Update Vehicle">
  <input type="hidden" name="inv_id"
    <% if(locals.inv_id) { %> value="<%= locals.inv_id %>"
    <% } %>>
  
</form>